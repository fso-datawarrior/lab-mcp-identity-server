# Scoped OAuth service app is the real credential.
# Any SSWS token is for manual curl only, never wired to the AI.

# Okta org base URL (e.g. https://example.okta.com)
OKTA_ORG_URL=

# OAuth service app client ID
OKTA_OAUTH_CLIENT_ID=

# Path to the private key PEM used for client assertion
OKTA_OAUTH_PRIVATE_KEY_PATH=

# Space-separated Okta OAuth scopes
OKTA_SCOPES="okta.users.read okta.groups.manage"

# Prefix for demo users/groups created by seed scripts
LAB3_DEMO_PREFIX="lab3-demo-"

# Shared secret for out-of-band approval confirmation (never expose as an MCP tool)
APPROVAL_SECRET=

# Optional audit log HMAC signing key. If unset, the log is hash-chained but not signed.
# LAB3_AUDIT_HMAC_KEY=

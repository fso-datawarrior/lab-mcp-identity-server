# Scoped OAuth service app is the real credential.
# Any SSWS token is for manual curl only, never wired to the AI.

# Okta org base URL (e.g. https://example.okta.com)
OKTA_ORG_URL=

# OAuth service app client ID
OKTA_OAUTH_CLIENT_ID=

# Path to the private key PEM used for client assertion
OKTA_OAUTH_PRIVATE_KEY_PATH=

# Optional OAuth key id (kid) when the service app has multiple keys
# OKTA_OAUTH_KEY_ID=

# Prefix for demo users/groups created by seed scripts
LAB3_DEMO_PREFIX="lab3-demo-"

# Space-separated Okta OAuth scopes (seed:demo may need okta.users.manage)
OKTA_SCOPES="okta.users.read okta.users.manage okta.groups.manage"

# Demo group id allowlist for group membership operations (real client only)
OKTA_DEMO_GROUP_ID=

# Okta client selection: mock (default) or real
OKTA_CLIENT_MODE=mock

# MCP actor principal recorded in the audit log (default: claude-desktop)
# LAB3_PRINCIPAL=claude-desktop

# Shared secret for out-of-band approval confirmation (never expose as an MCP tool)
APPROVAL_SECRET=

# Pending approval TTL in seconds (default 300). Raise for live demos (e.g. 900).
# LAB3_APPROVAL_TTL_SECONDS=900

# Optional audit log HMAC signing key. If unset, the log is hash-chained but not signed.
# LAB3_AUDIT_HMAC_KEY=
